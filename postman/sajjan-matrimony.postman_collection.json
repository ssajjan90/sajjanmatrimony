{
  "info": {
    "_postman_id": "sajjan-matrimony-collection-v1",
    "name": "Sajjan Matrimony API",
    "description": "Complete API collection for Sajjan Matrimony backend. Base URL: {{baseUrl}}\n\n## Setup\n1. Import `sajjan-matrimony.postman_environment.json` as the active environment.\n2. Run **Register** then **Login** — tokens and IDs are captured automatically.\n3. For admin operations, register a second user, manually set the `ADMIN` role in MongoDB, then log in with `Admin Login`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints — all public, no token required.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('success flag true', () => pm.expect(res.success).to.be.true);",
                  "if (res.data) {",
                  "    pm.environment.set('userId', res.data.id);",
                  "    pm.environment.set('userEmail', res.data.email);",
                  "    console.log('Registered userId:', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Raj Kumar\",\n  \"email\": \"raj.kumar@example.com\",\n  \"mobile\": \"9876543210\",\n  \"password\": \"Password@123\",\n  \"gender\": \"MALE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('access token present', () => pm.expect(res.data.accessToken).to.be.a('string'));",
                  "if (res.data) {",
                  "    pm.environment.set('accessToken', res.data.accessToken);",
                  "    pm.environment.set('refreshToken', res.data.refreshToken);",
                  "    pm.environment.set('userId', res.data.user.id);",
                  "    console.log('Access token stored.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrMobile\": \"raj.kumar@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (res.data) {",
                  "    pm.environment.set('accessToken', res.data.accessToken);",
                  "    pm.environment.set('refreshToken', res.data.refreshToken);",
                  "    console.log('Token refreshed.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh?refreshToken={{refreshToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"],
              "query": [
                { "key": "refreshToken", "value": "{{refreshToken}}" }
              ]
            }
          }
        },
        {
          "name": "Admin Login",
          "description": "Login as admin. Requires a user with ADMIN role set in MongoDB.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (res.data) {",
                  "    pm.environment.set('adminToken', res.data.accessToken);",
                  "    pm.environment.set('adminUserId', res.data.user.id);",
                  "    console.log('Admin token stored.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emailOrMobile\": \"admin@sajjanmatrimony.com\",\n  \"password\": \"AdminPass@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
